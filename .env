# 医疗知识问答系统配置

# ============================================================================
# Ollama配置
# ============================================================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=bge-m3:latest
OLLAMA_LLM_MODEL=qwen3:8b
OLLAMA_RERANK_MODEL=dengcao/bge-reranker-v2-m3:latest

# ============================================================================
# 重排序配置
# ============================================================================
ENABLE_RERANK=true
RERANK_INITIAL_TOP_K=20

# ============================================================================
# RAG配置 - 文档分块参数
# ============================================================================
CHUNK_SIZE=512
CHUNK_OVERLAP=50
CHUNK_MAX_LENGTH=2000

# ============================================================================
# RAG配置 - 检索参数
# ============================================================================
TOP_K=5
SIMILARITY_THRESHOLD=0.3

# ============================================================================
# LLM生成参数
# ============================================================================
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=512

# ============================================================================
# 对话历史控制参数（优化新增）
# ============================================================================
MAX_HISTORY_TURNS=5
MAX_ANSWER_LENGTH=300
MAX_CONTEXT_LENGTH=1500

# ============================================================================
# 向量数据库配置
# ============================================================================
CHROMA_PERSIST_DIRECTORY=./data/chroma_db

# ============================================================================
# 文档存储目录
# ============================================================================
DOCUMENTS_DIR=./data/documents

# ============================================================================
# 日志配置
# ============================================================================
LOG_LEVEL=INFO
LOG_FILE=./data/logs/app.log

# ============================================================================
# 缓存配置
# ============================================================================
ENABLE_EMBEDDING_CACHE=true
EMBEDDING_CACHE_SIZE=500

# ============================================================================
# 分块策略配置
# ============================================================================
CHUNK_BY_TITLE=true
PRESERVE_MEDICAL_TERMS=true

# ============================================================================
# API限流配置
# ============================================================================
ENABLE_RATE_LIMIT=true
RATE_LIMIT_QPS=10
RATE_LIMIT_UPLOAD_MAX=30
RATE_LIMIT_WINDOW=60

# ============================================================================
# CORS配置
# ============================================================================
CORS_ALLOWED_ORIGINS=*

# ============================================================================
# 重复检测配置
# ============================================================================
ENABLE_DUPLICATE_CHECK=true

# ============================================================================
# Embedding配置
# ============================================================================
EMBEDDING_MAX_LENGTH=2000

# ============================================================================
# LlamaParse配置（可选，用于高精度PDF解析）
# ============================================================================
# 申请API Key: https://cloud.llamaindex.ai/
# LLAMAPARSE_API_KEY=your_api_key_here
