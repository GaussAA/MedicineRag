# 医疗知识问答系统配置
# 复制此文件为 .env 并根据需要修改配置

# ============================================================================
# Ollama配置
# ============================================================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=bge-m3:latest
OLLAMA_LLM_MODEL=qwen3:8b
OLLAMA_RERANK_MODEL=dengcao/bge-reranker-v2-m3:latest

# ============================================================================
# 重排序配置
# ============================================================================
ENABLE_RERANK=true
RERANK_INITIAL_TOP_K=20

# ============================================================================
# RAG配置 - 文档分块参数
# ============================================================================
CHUNK_SIZE=512
CHUNK_OVERLAP=50
CHUNK_MAX_LENGTH=2000

# ============================================================================
# RAG配置 - 检索参数
# ============================================================================
TOP_K=5
SIMILARITY_THRESHOLD=0.3

# ============================================================================
# 置信度阈值配置
# ============================================================================
CONFIDENCE_HIGH=0.7        # 高置信度阈值（显示绿色）
CONFIDENCE_MEDIUM=0.5      # 中置信度阈值（显示黄色）

# ============================================================================
# LLM生成参数
# ============================================================================
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=512

# ============================================================================
# 对话历史控制参数
# ============================================================================
MAX_HISTORY_TURNS=5
MAX_ANSWER_LENGTH=300
MAX_CONTEXT_LENGTH=1500

# ============================================================================
# 向量数据库配置
# ============================================================================
CHROMA_PERSIST_DIRECTORY=./data/chroma_db

# ============================================================================
# 文档存储目录
# ============================================================================
DOCUMENTS_DIR=./data/documents

# ============================================================================
# 日志配置
# ============================================================================
LOG_LEVEL=INFO                              # 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=./data/logs/app.log                 # 日志文件路径
USE_STRUCTURED_LOG=false                    # 是否使用结构化JSON日志（方便日志分析系统）
LOG_MAX_BYTES=10485760                      # 日志文件最大字节数（默认10MB）
LOG_BACKUP_COUNT=5                          # 日志备份文件数量

# ============================================================================
# 缓存配置
# ============================================================================
ENABLE_EMBEDDING_CACHE=true
EMBEDDING_CACHE_SIZE=500
QUERY_CACHE_SIZE=100                         # 查询分析缓存大小（安全检查+问题类型检测）

# ============================================================================
# Agent配置
# ============================================================================
AGENT_MAX_STEPS=5                            # Agent最大推理步数
MIN_DOCS_FOR_ANSWER=2                        # Agent最少检索文档数，少于此数则继续检索

# ============================================================================
# 分块策略配置
# ============================================================================
CHUNK_BY_TITLE=true
PRESERVE_MEDICAL_TERMS=true

# ============================================================================
# API限流配置
# ============================================================================
ENABLE_RATE_LIMIT=true
RATE_LIMIT_QPS=10
RATE_LIMIT_QA_MAX=30                        # 问答接口每分钟最大请求数
RATE_LIMIT_UPLOAD_MAX=10                    # 上传接口每分钟最大请求数
RATE_LIMIT_OTHER_MAX=60                     # 其他接口每分钟最大请求数

# ============================================================================
# CORS配置
# ============================================================================
CORS_ALLOWED_ORIGINS=*                      # 生产环境建议限制具体域名

# ============================================================================
# 重复检测配置
# ============================================================================
ENABLE_DUPLICATE_CHECK=true

# ============================================================================
# Embedding配置
# ============================================================================
EMBEDDING_MAX_LENGTH=2000

# ============================================================================
# LlamaParse配置（可选，用于高精度PDF解析）
# ============================================================================
# 申请API Key: https://cloud.llamaindex.ai/
# LLAMAPARSE_API_KEY=your_api_key_here